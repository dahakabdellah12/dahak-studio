# Dashboard password (min 8 chars). Supports bcrypt hash ($2b$...) or plaintext (will be hashed at runtime).
DASHBOARD_PASSWORD=your_password_here
# 64-char hex secret for HMAC session tokens. Generate with: openssl rand -hex 32
DASHBOARD_SESSION_SECRET=your_64_char_hex_secret_here
# GitHub personal access token (repo scope) for reading/writing data files
GITHUB_TOKEN=ghp_your_token_here
# GitHub repo in owner/repo format
GITHUB_REPO=owner/repo-name
# Git branch for data storage
GITHUB_BRANCH=main
